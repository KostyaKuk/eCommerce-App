{
  "compilerOptions": {
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "allowJs": true,
    "skipLibCheck": true,
    "isolatedModules": false,
    "types": ["jest", "node"]
  },
  "include": ["src", "test", "src/global.d.ts"]
}

